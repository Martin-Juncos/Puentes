# Shared
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Opcional: lista separada por coma para otros orígenes del frontend en desarrollo
# Ejemplo: http://127.0.0.1:5173,http://192.168.0.24:5173
FRONTEND_URLS=
PORT=4000

# Frontend
VITE_API_BASE_URL=http://localhost:4000/api
VITE_PUBLIC_SITE_URL=http://localhost:5173
VITE_WHATSAPP_URL=https://wa.me/5491100000000?text=Hola%20Puentes

# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/puentes
# Obligatoria en produccion. No dejar este placeholder fuera de desarrollo local.
JWT_SECRET=change-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=puentes_token
COOKIE_SECURE=false

# Seed demo
# Credenciales opcionales para datos demo estables. Si se omiten, el seed genera passwords aleatorias y las imprime por consola.
SEED_ADMIN_EMAIL=admin@puentes.local
SEED_ADMIN_PASSWORD=
SEED_DEFAULT_PASSWORD=
# Mantener en false salvo que quieras seedear una base remota descartable de forma intencional.
SEED_ALLOW_REMOTE=false

# Resend / contact
# El formulario siempre intenta guardar la consulta en la base.
# El email institucional solo se envía si RESEND_API_KEY y RESEND_FROM están configurados correctamente.
RESEND_API_KEY=
RESEND_FROM="Puentes <onboarding@resend.dev>"
CONTACT_RECEIVER=contacto@puentes.local

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
