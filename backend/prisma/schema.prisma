generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINATION
  SECRETARY
  PROFESSIONAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum FamilyStatus {
  ACTIVE
  ARCHIVED
}

enum ChildStatus {
  ACTIVE
  PAUSED
  DISCHARGED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  RESCHEDULED
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  RESCHEDULED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum ContactInquiryStatus {
  NEW
  IN_REVIEW
  RESOLVED
}

enum MessageThreadStatus {
  OPEN
  ARCHIVED
}

enum MessagePriority {
  NORMAL
  HIGH
}

enum MessageThreadContextType {
  CHILD_CASE
  CONSULTA
  REPORTE
  INFORMACION
}

enum NotificationType {
  MESSAGE_NEW
  THREAD_ASSIGNED
  CHILD_CERTIFICATE_EXPIRING
}

model User {
  id                    String                      @id @default(cuid())
  fullName              String
  email                 String                      @unique
  passwordHash          String
  role                  Role
  status                UserStatus                  @default(ACTIVE)
  phone                 String?
  lastLoginAt           DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  professionalProfile   ProfessionalProfile?
  createdSessions       Session[]                   @relation("SessionCreatedBy")
  attendanceRecords     AttendanceRecord[]          @relation("AttendanceRegisteredBy")
  paymentRecords        PaymentRecord[]             @relation("PaymentRegisteredBy")
  authoredFollowUpNotes FollowUpNote[]              @relation("FollowUpAuthoredBy")
  assignedChildLinks    ChildProfessionalAssignment[] @relation("ChildAssignedBy")
  createdMessageThreads MessageThread[]             @relation("MessageThreadCreatedBy")
  threadParticipations  MessageParticipant[]
  authoredMessages      Message[]                   @relation("MessageAuthoredBy")
  notifications         Notification[]              @relation("NotificationUser")
  actedNotifications    Notification[]              @relation("NotificationActor")
}

model ProfessionalProfile {
  id             String                      @id @default(cuid())
  userId         String                      @unique
  discipline     String
  bio            String?
  calendarColor  String?
  isHighlighted  Boolean                     @default(true)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  user           User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    ChildProfessionalAssignment[]
  sessions       Session[]
  followUpNotes  FollowUpNote[]              @relation("ProfessionalFollowUps")
}

model Service {
  id              String          @id @default(cuid())
  name            String          @unique
  description     String
  status          ServiceStatus   @default(ACTIVE)
  durationMinutes Int             @default(60)
  colorTag        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  sessions        Session[]
  assignments     ChildProfessionalAssignment[]
}

model Family {
  id                         String         @id @default(cuid())
  displayName                String
  primaryContactName         String
  primaryContactRelationship String
  phone                      String
  email                      String?
  address                    String?
  notes                      String?
  status                     FamilyStatus   @default(ACTIVE)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  children                   Child[]
  payments                   PaymentRecord[]
}

model Child {
  id                             String                      @id @default(cuid())
  firstName                      String
  lastName                       String
  birthDate                      DateTime
  schoolName                     String?
  notes                          String?
  disabilityCertificateIssuedAt  DateTime?
  disabilityCertificateExpiresAt DateTime?
  disabilityCertificateIssuedBy  String?
  status                         ChildStatus                 @default(ACTIVE)
  familyId                       String
  createdAt                      DateTime                    @default(now())
  updatedAt                      DateTime                    @updatedAt
  family                         Family                      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  assignments                    ChildProfessionalAssignment[]
  sessions                       Session[]
  payments                       PaymentRecord[]
  followUps                      FollowUpNote[]
  messageThreads                 MessageThread[]
  notifications                  Notification[]

  @@index([lastName])
}

model ChildProfessionalAssignment {
  id               String              @id @default(cuid())
  childId          String
  professionalId   String
  serviceId        String?
  assignedByUserId String?
  notes            String?
  createdAt        DateTime            @default(now())
  child            Child               @relation(fields: [childId], references: [id], onDelete: Cascade)
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service          Service?            @relation(fields: [serviceId], references: [id])
  assignedBy       User?               @relation("ChildAssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([childId, professionalId, serviceId])
}

model Session {
  id              String           @id @default(cuid())
  childId         String
  professionalId  String
  serviceId       String
  createdByUserId String
  startsAt        DateTime         @db.Timestamptz(3)
  endsAt          DateTime         @db.Timestamptz(3)
  status          SessionStatus    @default(SCHEDULED)
  adminNotes      String?
  internalNotes   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  child           Child            @relation(fields: [childId], references: [id], onDelete: Cascade)
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id])
  service         Service          @relation(fields: [serviceId], references: [id])
  createdBy       User             @relation("SessionCreatedBy", fields: [createdByUserId], references: [id])
  attendance      AttendanceRecord?
  followUps       FollowUpNote[]
  payments        PaymentRecord[]

  @@index([startsAt])
  @@index([professionalId, startsAt])
}

model FollowUpNote {
  id             String              @id @default(cuid())
  childId        String
  professionalId String
  authorUserId   String
  sessionId      String?
  followUpDate   DateTime
  title          String?
  summary        String?
  note           String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  child          Child               @relation(fields: [childId], references: [id], onDelete: Cascade)
  professional   ProfessionalProfile @relation("ProfessionalFollowUps", fields: [professionalId], references: [id], onDelete: Cascade)
  authorUser     User                @relation("FollowUpAuthoredBy", fields: [authorUserId], references: [id])
  session        Session?            @relation(fields: [sessionId], references: [id])

  @@index([followUpDate])
}

model MessageThread {
  id              String              @id @default(cuid())
  childId         String?
  contextType     MessageThreadContextType @default(CHILD_CASE)
  subject         String
  createdByUserId String
  status          MessageThreadStatus @default(OPEN)
  priority        MessagePriority     @default(NORMAL)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  child           Child?              @relation(fields: [childId], references: [id], onDelete: Cascade)
  createdByUser   User                @relation("MessageThreadCreatedBy", fields: [createdByUserId], references: [id])
  participants    MessageParticipant[]
  messages        Message[]
  notifications   Notification[]

  @@index([childId, updatedAt])
  @@index([status, updatedAt])
}

model MessageParticipant {
  id         String        @id @default(cuid())
  threadId    String
  userId      String
  lastReadAt  DateTime?
  createdAt   DateTime     @default(now())
  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
}

model Message {
  id           String        @id @default(cuid())
  threadId      String
  authorUserId  String
  body          String
  createdAt     DateTime      @default(now())
  thread        MessageThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorUser    User           @relation("MessageAuthoredBy", fields: [authorUserId], references: [id])

  @@index([threadId, createdAt])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  bodyPreview String?
  dedupeKey   String?
  threadId    String?
  childId     String?
  actorUserId String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  thread      MessageThread?   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  child       Child?           @relation(fields: [childId], references: [id], onDelete: Cascade)
  actorUser   User?            @relation("NotificationActor", fields: [actorUserId], references: [id])

  @@index([userId, readAt, createdAt])
  @@index([threadId])
  @@index([childId])
  @@unique([userId, dedupeKey])
}

model AttendanceRecord {
  id                 String           @id @default(cuid())
  sessionId          String           @unique
  status             AttendanceStatus @default(PENDING)
  notes              String?
  registeredByUserId String
  registeredAt       DateTime         @default(now())
  session            Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registeredBy       User             @relation("AttendanceRegisteredBy", fields: [registeredByUserId], references: [id])
}

model PaymentRecord {
  id               String        @id @default(cuid())
  childId          String
  familyId         String
  sessionId        String?
  amount           Float
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  dueDate          DateTime?
  notes            String?
  recordedByUserId String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  child            Child         @relation(fields: [childId], references: [id], onDelete: Cascade)
  family           Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  session          Session?      @relation(fields: [sessionId], references: [id])
  recordedBy       User          @relation("PaymentRegisteredBy", fields: [recordedByUserId], references: [id])

  @@index([status])
}

model ContactInquiry {
  id        String               @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  message   String
  status    ContactInquiryStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status, createdAt])
}

model AppSettings {
  id                            String   @id
  centerName                    String   @default("Puentes")
  institutionalEmail            String   @default("contacto@puentes.local")
  institutionalPhone            String   @default("+54 9 3777 679100")
  whatsappUrl                   String   @default("https://wa.me/5493777679100?text=Hola%20Puentes")
  address                       String   @default("Buenos Aires, Argentina")
  businessHoursSummary          String   @default("Lunes a viernes de 8 a 20 h.")
  defaultServiceDurationMinutes Int      @default(60)
  defaultSessionDurationMinutes Int      @default(45)
  slotIntervalMinutes           Int      @default(30)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}
